# PAYMENT CONFIGURATION
# Options: "demo", "stripe", "razorpay"
PAYMENT_MODE=stripe

# ==================== STRIPE CONFIGURATION ====================
# Get these from: https://dashboard.stripe.com/apikeys

# Secret key for server-side operations (KEEP THIS SECRET!)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook secret for validating Stripe events
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# ==================== RAZORPAY CONFIGURATION (Optional) ====================
# If you want to keep Razorpay as fallback, add these:
# RAZORPAY_KEY=your_razorpay_key_here
# RAZORPAY_SECRET=your_razorpay_secret_here

# ==================== DATABASE CONFIGURATION ====================
MONGODB_URL=mongodb://localhost:27017/studynotion

# ==================== JWT CONFIGURATION ====================
JWT_SECRET=your_jwt_secret_key_here

# ==================== EMAIL CONFIGURATION ====================
MAIL_HOST=smtp.gmail.com
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# ==================== CLOUDINARY CONFIGURATION ====================
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==================== CORS CONFIGURATION ====================
CORS_ORIGIN=http://localhost:5173
