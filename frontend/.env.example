# PAYMENT CONFIGURATION
# Options: "demo", "stripe", "razorpay"
VITE_APP_PAYMENT_MODE=stripe

# ==================== STRIPE CONFIGURATION ====================
# Get these from: https://dashboard.stripe.com/apikeys
# This is the PUBLISHABLE key (safe to expose in frontend)
VITE_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ==================== RAZORPAY CONFIGURATION (Optional) ====================
# If you want to keep Razorpay as fallback:
# VITE_APP_RAZORPAY_KEY=your_razorpay_key_here

# ==================== API CONFIGURATION ====================
VITE_APP_BASE_URL=http://localhost:4000/api/v1
